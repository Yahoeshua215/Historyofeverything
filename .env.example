# OpenAI API key — required for the /api/identify route.
# Copy this file to .env.local and fill in your key (never commit .env.local).
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: override the model (defaults to gpt-4o-mini).
# Must be a vision + Structured Outputs capable model. Higher quality: gpt-4o
# HISTORY_LENS_MODEL=gpt-4o-mini
