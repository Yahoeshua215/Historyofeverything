# Anthropic API key — required for the /api/identify route.
# Copy this file to .env.local and fill in your key (never commit .env.local).
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: override the Claude model (defaults to claude-opus-4-8).
# Cheaper alternatives: claude-sonnet-4-6, claude-haiku-4-5
# HISTORY_LENS_MODEL=claude-opus-4-8
